# ═══════════════════════════════════════════════════════════════
# Content Engine - Docker Environment Configuration Template
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your API keys:
#   cp .env.docker .env
# Then edit .env with your actual credentials
# ═══════════════════════════════════════════════════════════════

# ── OpenAI ─────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# ── Anthropic ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# ── ElevenLabs (TTS) ───────────────────────────────────────────
ELEVENLABS_API_KEY=...
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB
ELEVENLABS_MODEL=eleven_turbo_v2_5
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_192
ELEVENLABS_STABILITY=0.55
ELEVENLABS_SIMILARITY_BOOST=0.80
ELEVENLABS_STYLE=0.35

# ── Pexels (Stock Video) ───────────────────────────────────────
PEXELS_API_KEY=...

# ── Telegram Bot ───────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=...

# ── Captions ───────────────────────────────────────────────────
CAPTIONS_ENABLED=true
CAPTIONS_FONT=Arial
CAPTIONS_FONT_SIZE=18
CAPTIONS_MAX_WORDS_PER_CHUNK=3
CAPTIONS_UPPERCASE=true

# ── YouTube Upload ─────────────────────────────────────────────
YOUTUBE_DEFAULT_PRIVACY=public
YOUTUBE_DEFAULT_CATEGORY=education

# ── API Authentication ─────────────────────────────────────────
# Enable API key authentication (set to false for development)
API_AUTH_ENABLED=true

# ── CORS Configuration ─────────────────────────────────────────
# Allowed origins for CORS (comma-separated)
# Development: use "*" to allow all origins
# Production: specify exact origins (e.g., "https://yourdomain.com,https://app.yourdomain.com")
CORS_ALLOWED_ORIGINS=*

# ── Security & Encryption ──────────────────────────────────────
# Generate secrets with: python scripts/generate_secrets.py
# ENCRYPTION_KEY=<fernet-key-here>

# ── Database & Redis Passwords ─────────────────────────────────
# For development, defaults to 'postgres' if not set
# For production, MUST set strong passwords (see generate_secrets.py)
# DB_PASSWORD=<strong-password-here>
# REDIS_PASSWORD=<strong-password-here>

# ── Database URLs ──────────────────────────────────────────────
# Development defaults (no auth):
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/content_engine
# DATABASE_URL_SYNC=postgresql+psycopg2://postgres:postgres@postgres:5432/content_engine
# REDIS_URL=redis://redis:6379/0
# CELERY_BROKER_URL=redis://redis:6379/0
# CELERY_RESULT_BACKEND=redis://redis:6379/1

# Production with passwords (uncomment and update after running generate_secrets.py):
# DATABASE_URL=postgresql+asyncpg://postgres:${DB_PASSWORD}@postgres:5432/content_engine
# DATABASE_URL_SYNC=postgresql+psycopg2://postgres:${DB_PASSWORD}@postgres:5432/content_engine
# REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0
# CELERY_BROKER_URL=redis://:${REDIS_PASSWORD}@redis:6379/0
# CELERY_RESULT_BACKEND=redis://:${REDIS_PASSWORD}@redis:6379/1
