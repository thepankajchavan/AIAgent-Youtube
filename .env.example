# ── Application ───────────────────────────────────────────────
APP_NAME=content-engine
APP_ENV=development
DEBUG=true
LOG_LEVEL=DEBUG

# ── Database (PostgreSQL) ────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/content_engine
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:postgres@localhost:5432/content_engine

# ── Redis / Celery ───────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── OpenAI ───────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# ── Anthropic ────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# ── ElevenLabs (TTS) ────────────────────────────────────────
ELEVENLABS_API_KEY=...
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ── Pexels (Stock Video) ────────────────────────────────────
PEXELS_API_KEY=...

# ── YouTube Data API v3 ─────────────────────────────────────
YOUTUBE_CLIENT_SECRETS_FILE=client_secrets.json
YOUTUBE_TOKEN_FILE=youtube_token.json

# ── Media Paths ──────────────────────────────────────────────
MEDIA_DIR=media
