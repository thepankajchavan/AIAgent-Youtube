# ── Application ───────────────────────────────────────────────
APP_NAME=content-engine
APP_ENV=development
DEBUG=true
LOG_LEVEL=DEBUG

# ── API Authentication ────────────────────────────────────────
# Set to false for local development (no API key required)
# Set to true in production and use X-API-Key header
API_AUTH_ENABLED=false

# ── Database (PostgreSQL) ────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/content_engine
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:postgres@localhost:5432/content_engine

# ── Redis / Celery ───────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── OpenAI ───────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# ── Anthropic ────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# ── ElevenLabs (TTS) ────────────────────────────────────────
ELEVENLABS_API_KEY=...
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ── Pexels (Stock Video) ────────────────────────────────────
PEXELS_API_KEY=...

# ── AI Video Generation ─────────────────────────────────────
# Set to true to enable AI video generation (Runway/Stability/Kling)
AI_VIDEO_ENABLED=false
AI_VIDEO_STRATEGY=stock_only
AI_VIDEO_PRIMARY_PROVIDER=runway
RUNWAY_API_KEY=
STABILITY_API_KEY=
KLING_ACCESS_KEY=
KLING_SECRET_KEY=

# ── YouTube Data API v3 ─────────────────────────────────────
YOUTUBE_CLIENT_SECRETS_FILE=client_secrets.json
YOUTUBE_TOKEN_FILE=youtube_token.json

# ── Telegram Bot ─────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
API_BASE_URL=http://localhost:8000

# ── Media Paths ──────────────────────────────────────────────
MEDIA_DIR=media
