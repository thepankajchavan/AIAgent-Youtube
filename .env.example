# ── Application ───────────────────────────────────────────────
APP_NAME=content-engine
APP_ENV=development
DEBUG=true
LOG_LEVEL=DEBUG

# ── API Authentication ────────────────────────────────────────
# Set to false for local development (no API key required)
# Set to true in production and use X-API-Key header
API_AUTH_ENABLED=false

# ── Database (PostgreSQL) ────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/content_engine
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:postgres@localhost:5432/content_engine

# ── Redis / Celery ───────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── OpenAI ───────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# ── Anthropic ────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# ── ElevenLabs (TTS) ────────────────────────────────────────
ELEVENLABS_API_KEY=...
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB
ELEVENLABS_MODEL=eleven_turbo_v2_5
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_192
ELEVENLABS_STABILITY=0.55
ELEVENLABS_SIMILARITY_BOOST=0.80
ELEVENLABS_STYLE=0.35

# ── Pexels (Stock Video) ────────────────────────────────────
PEXELS_API_KEY=...

# ── AI Video Generation ─────────────────────────────────────
# Set to true to enable AI video generation (Runway/Stability/Kling)
AI_VIDEO_ENABLED=true
AI_VIDEO_STRATEGY=ai_only
AI_VIDEO_PRIMARY_PROVIDER=runway
RUNWAY_API_KEY=
STABILITY_API_KEY=
KLING_ACCESS_KEY=
KLING_SECRET_KEY=

# ── AI Image Generation (DALL-E / GPT-image-1) ───────────────
# Scene-accurate images animated with Ken Burns effect — much cheaper than AI video
AI_IMAGES_ENABLED=true
AI_IMAGES_MODEL=dall-e-3
AI_IMAGES_SIZE=1024x1792
AI_IMAGES_QUALITY=standard
AI_IMAGES_MAX_COST_PER_VIDEO=0.50

# ── AI Video Quality Enhancements ────────────────────────────
VISUAL_CONTINUITY_ENABLED=true
PROMPT_REWRITING_ENABLED=false
STOCK_QUERY_EXPANSION_ENABLED=true
COLOR_NORMALIZATION_ENABLED=false
COLOR_NORMALIZATION_PROFILE=auto

# ── Captions ─────────────────────────────────────────────────
CAPTIONS_ENABLED=true
CAPTIONS_FONT=Arial
CAPTIONS_FONT_SIZE=28
CAPTIONS_MAX_WORDS_PER_CHUNK=3
CAPTIONS_UPPERCASE=true
CAPTIONS_STYLE=classic                  # classic | karaoke | bounce | typewriter
CAPTIONS_POSITION=bottom                # bottom | center | top
CAPTIONS_PRIMARY_COLOR=FFFFFF           # BGR hex (white text)
CAPTIONS_ACCENT_COLOR=00FFFF            # BGR hex (yellow karaoke highlight)
CAPTIONS_OUTLINE_COLOR=000000           # BGR hex (black outline)
CAPTIONS_SHADOW_COLOR=80000000          # ABGR hex (translucent shadow)

# ── Video Transitions ─────────────────────────────────────────
TRANSITIONS_ENABLED=true
TRANSITION_STYLE=auto                   # auto | uniform | fade | dissolve | wipeleft | ...
TRANSITION_DURATION=0.3                 # Base duration (seconds)
TRANSITION_DURATION_MIN=0.2
TRANSITION_DURATION_MAX=0.8

# ── Background Music (Pixabay) ─────────────────────────────────
BGM_ENABLED=false                       # Disabled by default
PIXABAY_API_KEY=
BGM_VOLUME_DB=-18.0                     # BGM volume (background level)
TTS_VOLUME_DB=-3.0                      # TTS volume (foreground level)
BGM_FADE_IN_DURATION=1.0                # Fade-in at video start (seconds)
BGM_FADE_OUT_DURATION=2.0               # Fade-out at video end (seconds)
BGM_DUCKING_ENABLED=true                # Sidechain compression during narration
BGM_DUCKING_AMOUNT_DB=-6.0              # Extra BGM reduction during speech
BGM_DEFAULT_MOOD=uplifting              # Fallback mood

# ── Scene Director ──────────────────────────────────────────────
SCENE_DIRECTOR_ENABLED=false
SCENE_DIRECTOR_PROVIDER=openai
CREATIVE_PRESET=auto                    # auto | minimal | cinematic | energetic

# ── Content Quality ────────────────────────────────────────────
VOICE_PROFILE_ENABLED=true              # Map mood → tuned TTS voice params
HOOK_MIN_SCORE=0.3                      # Minimum hook engagement score (0.0-1.0)
NICHE_TEMPLATES_ENABLED=true            # Use niche-specific tone templates
MOOD_CREATIVE_GLUE_ENABLED=false        # Let mood drive caption/transition style
PER_BEAT_TTS_ENABLED=false              # Dynamic expressiveness per script beat
SEARCH_MULTI_QUERY_ENABLED=true         # Expand topic into 2-3 search queries
SEARCH_CREDIBILITY_ENABLED=true         # Rank sources by domain authority

# ── YouTube Data API v3 ─────────────────────────────────────
YOUTUBE_API_KEY=
YOUTUBE_CLIENT_SECRETS_FILE=client_secrets.json
YOUTUBE_TOKEN_FILE=youtube_token.json
YOUTUBE_DEFAULT_PRIVACY=public
YOUTUBE_DEFAULT_CATEGORY=education

# ── Telegram Bot ─────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
API_BASE_URL=http://localhost:8000

# ── Self-Improvement System ───────────────────────────────────
SELF_IMPROVEMENT_ENABLED=false
YOUTUBE_ANALYTICS_ENABLED=false
TRENDS_ENABLED=false
PROMPT_AB_TESTING_ENABLED=false

# ── Trend Fetching (Multi-Source) ──────────────────────────────
TRENDS_CATEGORIES=technology,entertainment,education
TRENDS_REGION=US
TRENDS_FETCH_INTERVAL_HOURS=4            # Hours between trend fetches
TRENDS_REDDIT_ENABLED=false              # Enable Reddit as trend source
TRENDS_REDDIT_SUBREDDITS=technology,science,worldnews,futurology
TRENDS_TWITTER_ENABLED=false             # Enable Twitter/X (best-effort)
TRENDS_MIN_QUALITY_SCORE=40.0            # Min quality score for scheduling
TRENDS_EXPIRY_HOURS=24                   # Hours before trend expires

# Analytics Settings
YOUTUBE_ANALYTICS_COLLECTION_HOUR=3
YOUTUBE_ANALYTICS_LOOKBACK_DAYS=7

# Pattern Analysis
PATTERN_ANALYSIS_MIN_VIDEOS=10
PATTERN_ANALYSIS_SCHEDULE=weekly

# ── Auto-Scheduling (Smart) ─────────────────────────────────
AUTO_SCHEDULE_ENABLED=false
AUTO_SCHEDULE_MAX_DAILY=2
AUTO_SCHEDULE_NICHE=
AUTO_SCHEDULE_VISUAL_STRATEGY=stock_only
AUTO_SCHEDULE_SKIP_UPLOAD=false
AUTO_SCHEDULE_COOLDOWN_HOURS=4
AUTO_SCHEDULE_TIMES=10:00,18:00              # Fixed daily times (HH:MM UTC, comma-separated)
AUTO_SCHEDULE_ADMIN_CHAT_ID=0            # Telegram chat ID for admin alerts
AUTO_SCHEDULE_QUALITY_THRESHOLD=40.0     # Min topic quality score
AUTO_SCHEDULE_DIVERSITY_WINDOW=3         # Last N videos for diversity check
AUTO_SCHEDULE_PERFORMANCE_FEEDBACK=true  # Boost topics similar to winners

# ── AI Thumbnails ───────────────────────────────────────────
AI_THUMBNAIL_ENABLED=false
AI_THUMBNAIL_TEXT_OVERLAY=true

# ── Multi-Voice ─────────────────────────────────────────────
MULTI_VOICE_ENABLED=false
VOICE_MAP_SCIENCE=
VOICE_MAP_HISTORY=
VOICE_MAP_TECHNOLOGY=
VOICE_MAP_MOTIVATION=
VOICE_MAP_ENTERTAINMENT=
VOICE_MAP_DEFAULT=

# ── Multi-Language ──────────────────────────────────────────
MULTI_LANGUAGE_ENABLED=false
DEFAULT_LANGUAGE=en
TRANSLATION_PROVIDER=openai

# ── Video Pacing ────────────────────────────────────────────
PACING_ENABLED=false
PACING_STYLE=auto
PACING_BASE_SPEED=1.0
PACING_MIN_SPEED=0.75
PACING_MAX_SPEED=1.25

# ── Media Paths ──────────────────────────────────────────────
MEDIA_DIR=media
